---
import Layout from '../../layouts/Layout.astro';
import { ciudadesData, getCiudades, filterByCategory } from '../../data/ciudades';
import RutaGastronomica from '../../components/RutaGastronomica.astro';

export function getStaticPaths() {
  return getCiudades().map(ciudad => ({
    params: { ciudad: ciudad.toLowerCase() },
    props: { ciudad }
  }));
}

const { ciudad } = Astro.props;
const ciudadNombre = ciudad.charAt(0).toUpperCase() + ciudad.slice(1);
const data = ciudadesData[ciudadNombre as keyof typeof ciudadesData];

const preciosArray = Object.entries(data.precios).map(([cat, rango]) => ({
  categoria: cat,
  min: rango.min,
  max: rango.max,
  promedio: (rango.min + rango.max) / 2
}));

// Obtener categorías únicas
const categorias = [...new Set(data.restaurantes.map(r => r.categoria))];

// Función para generar URL de imagen placeholder por categoría
const getRestaurantImage = (categoria: string, idx: number) => {
  const keywords: Record<string, string> = {
    'Restaurante': 'chinese-food,restaurant',
    'Cafetería': 'coffee-shop,cafe',
    'Casa de Té': 'tea-house,asian',
    'Bar/Cocktail': 'cocktail-bar,nightlife',
    'Vida Nocturna': 'nightclub,party'
  };
  const keyword = keywords[categoria] || 'restaurant';
  // Usar Unsplash Source con keywords específicas
  return `https://images.unsplash.com/photo-${getUnsplashId(categoria, idx)}?w=400&h=200&fit=crop`;
};

// IDs reales de Unsplash para cada categoría
const getUnsplashId = (cat: string, idx: number) => {
  const ids: Record<string, string[]> = {
    'Restaurante': ['15593d2a3c9a77f8', '151724873544b9a5e', '155536676989f4a8d', '1414615052257-66b9a6a52a7'],
    'Cafetería': ['1509049461765f39ca', '1521019426853-453f44c55bcc', '1525625422297-35e96aa1a73d', '1497933701321-e1c73a8b9f6a'],
    'Casa de Té': ['1576055744230-16a5a0e69e8d', '1544798868-0b5e67e4f7c8', '1576055742379-42b4e96d7a7d', '1563806429-5a5e5a81aa6e'],
    'Bar/Cocktail': ['1514362545857-3bcbe82439ca', '1572394969825-8986c8e82f28', '1536968734890-8b9c25f6d71e', '1470332374589-90c7e7f66675'],
    'Vida Nocturna': ['1545124942-2a6dc969bb63', '1566410900-2b91b7a8c6d5', '1516450360452-90c4b6a8c6d5', '1514528492681-1b5c7f6d6d5e']
  };
  const categoryIds = ids[cat] || ids['Restaurante'];
  return categoryIds[idx % categoryIds.length];
};
---

<Layout title={`${ciudadNombre} - Guía Gastronómica`}>
  <!-- Hero -->
  <section class="py-16" style={`background: linear-gradient(135deg, ${data.color} 0%, ${data.color}dd 100%)`}>
    <div class="container mx-auto px-4">
      <a href="/poc-chinese-gastronomy/" class="text-white/80 hover:text-white mb-4 inline-flex items-center gap-2">
        ← Volver
      </a>
      
      <div class="text-white mt-8">
        <div class="flex items-center gap-3 mb-4">
          <h1 class="text-5xl md:text-6xl font-heading">{ciudadNombre}</h1>
          <span class="bg-white/20 backdrop-blur px-4 py-2 rounded-lg text-lg">{data.tier}</span>
        </div>
        <p class="text-xl md:text-2xl max-w-3xl mb-8">{data.descripcion}</p>
        
        <div class="flex flex-wrap gap-6">
          <div class="bg-white/10 backdrop-blur px-6 py-4 rounded-lg">
            <div class="text-4xl font-bold text-chinese-gold">{data.promedio_diario}</div>
            <div class="text-sm">CNY por día</div>
          </div>
          <div class="bg-white/10 backdrop-blur px-6 py-4 rounded-lg">
            <div class="text-4xl font-bold text-chinese-gold">{data.restaurantes.length}</div>
            <div class="text-sm">Establecimientos</div>
          </div>
          <div class="bg-white/10 backdrop-blur px-6 py-4 rounded-lg">
            <div class="text-4xl font-bold text-chinese-gold">{data.especialidades.length}</div>
            <div class="text-sm">Especialidades</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Rutas Gastronómicas -->
  {data.rutas && data.rutas.length > 0 && (
    <section class="container mx-auto px-4 py-12 bg-gradient-to-r from-gray-50 to-white">
      <h2 class="text-3xl font-heading text-chinese-red mb-8">🗺️ Rutas Gastronómicas</h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {data.rutas.map((ruta, idx) => (
          <RutaGastronomica 
            ruta={ruta} 
            ciudadColor={data.color} 
            index={idx} 
          />
        ))}
      </div>
    </section>
  )}

  <!-- Especialidades -->
  <section class="container mx-auto px-4 py-12">
    <h2 class="text-3xl font-heading text-chinese-red mb-8">🥘 Especialidades Locales</h2>
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
      {data.especialidades.map(esp => (
        <div class="bg-white p-6 rounded-lg shadow-md hover:shadow-xl transition border-l-4" style={`border-color: ${data.color}`}>
          <div class="flex items-start gap-3">
            <span class="text-3xl">🍜</span>
            <div>
              <h3 class="font-bold text-lg mb-1">{esp.split('(')[0].trim()}</h3>
              {esp.includes('(') && (
                <p class="text-sm text-gray-600">{esp.match(/\((.*?)\)/)?.[1]}</p>
              )}
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Filtros y Restaurantes -->
  <section class="bg-gray-100 py-12">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl font-heading text-chinese-red mb-8">🍽️ Restaurantes, Cafeterías y Casas de Té</h2>
      
      <!-- Filtros -->
      <div class="mb-8 flex flex-wrap gap-3">
        <button 
          class="filter-btn px-6 py-2 rounded-full font-semibold transition duration-200 active:shadow-xl active:-translate-y-0.5" 
          data-filter="all"
          style={`background-color: ${data.color}; color: white`}
        >
          Todos ({data.restaurantes.length})
        </button>
        {categorias.map(cat => {
          const count = data.restaurantes.filter(r => r.categoria === cat).length;
          return (
            <button 
              class="filter-btn px-6 py-2 rounded-full font-semibold transition duration-200 bg-white hover:shadow-lg active:shadow-xl active:-translate-y-0.5" 
              data-filter={cat}
              style={`color: ${data.color}`}
            >
              {cat} ({count})
            </button>
          );
        })}
      </div>

      <!-- Grid de Restaurantes -->
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6" id="restaurantes-grid">
        {data.restaurantes.map((rest, idx) => (
          <div class="restaurant-card bg-white rounded-xl shadow-lg hover:shadow-2xl transition-all duration-300 overflow-hidden opacity-100 translate-y-0" data-categoria={rest.categoria}>
            <div class="h-32 relative overflow-hidden">
              <img src={getRestaurantImage(rest.categoria, idx)} alt={rest.nombre} class="w-full h-full object-cover" loading="lazy" />
              <div class="absolute top-4 right-4 bg-white px-3 py-1 rounded-full text-xl shadow-md">
                {rest.rating}
              </div>
              <div class="absolute top-4 left-4">
                <span class="bg-chinese-gold text-white px-3 py-1 rounded text-xs font-bold shadow-md">
                  #{idx + 1}
                </span>
              </div>
              <div class="absolute bottom-3 left-4 bg-white/90 backdrop-blur px-3 py-1 rounded-full text-xs shadow-md">
                {rest.categoria}
              </div>
            </div>
            
            <div class="p-6">
              <h3 class="text-lg font-heading mb-2">{rest.nombre}</h3>
              <div class="flex items-center gap-2 mb-3 text-sm flex-wrap">
                <span class="text-gray-500">{rest.tipo}</span>
                <span class="text-chinese-gold">•</span>
                <span class="font-semibold" style={`color: ${data.color}`}>{rest.precio}</span>
                {rest.especialidadTag && (
                  <>
                    <span class="text-chinese-gold">•</span>
                    <span 
                      class="px-2 py-1 rounded-full text-xs font-bold text-white"
                      style={`background-color: ${data.color}`}
                    >
                      {rest.especialidadTag}
                    </span>
                  </>
                )}
              </div>
              
              <div class="bg-gray-50 p-4 rounded-lg mb-3">
                <p class="text-sm font-medium">{rest.destacado}</p>
              </div>

              {rest.amapUrl && (
                <a 
                  href={rest.amapUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-2 px-4 py-2 rounded-lg text-sm font-semibold text-white hover:opacity-90 transition-opacity w-full justify-center"
                  style={`background-color: ${data.color}`}
                >
                  <span>📍</span>
                  <span>Ver en AMap (高德地图)</span>
                </a>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Gráfico de Precios -->
  <section class="container mx-auto px-4 py-12">
    <h2 class="text-3xl font-heading text-chinese-red mb-8">💰 Rangos de Precio</h2>
    
    <div class="bg-white p-8 rounded-xl shadow-lg">
      <div class="space-y-6">
        {preciosArray.map(item => (
          <div>
            <div class="flex justify-between mb-2">
              <span class="font-semibold">{item.categoria}</span>
              <span class="text-gray-600">{item.min} - {item.max} CNY</span>
            </div>
            <div class="bg-gray-200 rounded-full h-6 relative overflow-hidden">
              <div 
                class="h-full rounded-full flex items-center justify-end px-3 text-white text-sm font-bold"
                style={`width: ${(item.promedio / Math.max(...preciosArray.map(p => p.promedio))) * 100}%; background-color: ${data.color}`}
              >
                {Math.round(item.promedio)} CNY
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Navegación -->
  <section class="container mx-auto px-4 py-12">
    <h3 class="text-2xl font-heading text-chinese-red mb-6">Explorar Otras Ciudades</h3>
    <div class="flex flex-wrap gap-3">
      {getCiudades()
        .filter(c => c !== ciudadNombre)
        .map(otraCiudad => (
          <a
            href={`/poc-chinese-gastronomy/ciudad/${otraCiudad.toLowerCase()}`}
            class="px-6 py-3 bg-white rounded-lg shadow hover:shadow-lg transition border-2 border-transparent hover:border-chinese-red"
          >
            {otraCiudad}
          </a>
        ))
      }
    </div>
  </section>
</Layout>

<script>
  // Sistema de filtros
  document.addEventListener('DOMContentLoaded', () => {
    const filterBtns = document.querySelectorAll('.filter-btn');
    const cards = document.querySelectorAll('.restaurant-card');
    
    filterBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const filter = btn.getAttribute('data-filter');
        
        // Update active state - añade/remueve clases Tailwind
        filterBtns.forEach(b => {
          b.classList.remove('shadow-xl', '-translate-y-0.5');
        });
        btn.classList.add('shadow-xl', '-translate-y-0.5');
        
        // Filter cards con animation
        cards.forEach(card => {
          if (filter === 'all' || card.getAttribute('data-categoria') === filter) {
            card.style.display = 'block';
            // Usar Tailwind animate classes
            card.classList.remove('opacity-0', 'translate-y-2');
            card.classList.add('opacity-100', 'translate-y-0', 'transition-all', 'duration-300');
          } else {
            card.style.display = 'none';
          }
        });
      });
    });
  });
</script>

