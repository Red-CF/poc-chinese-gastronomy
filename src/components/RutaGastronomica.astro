---
// Componente: RutaGastronomica.astro
// Visualización mejorada de rutas gastronómicas con timeline visual

interface Props {
  ruta: {
    nombre: string;
    duracion: string;
    stops: string;
    costo: string;
    distancia: string;
    amapUrl?: string;
  };
  ciudadColor: string;
  index: number;
}

const { ruta, ciudadColor, index } = Astro.props;

// Parse stops format "A → B → C" a array
const parseStops = (stopsStr: string): string[] => {
  return stopsStr
    .split('→')
    .map(stop => stop.trim())
    .filter(stop => stop.length > 0);
};

const stops = parseStops(ruta.stops);
---

<div 
  class="bg-white rounded-xl shadow-lg hover:shadow-2xl transition-all duration-300 overflow-hidden border-l-4"
  style={`border-color: ${ciudadColor}`}
>
  <!-- Header con badge de número -->
  <div class="bg-gradient-to-r from-gray-50 to-white p-6 border-b border-gray-100">
    <div class="flex items-start justify-between gap-4">
      <div class="flex-1">
        <div class="flex items-center gap-3 mb-2">
          <span 
            class="inline-flex items-center justify-center w-8 h-8 rounded-full text-white font-bold text-sm"
            style={`background-color: ${ciudadColor}`}
          >
            #{index + 1}
          </span>
          <h3 class="font-bold text-xl" style={`color: ${ciudadColor}`}>
            {ruta.nombre}
          </h3>
        </div>
        <div class="flex items-center gap-2 text-sm text-gray-600">
          <span>⏰</span>
          <span>{ruta.duracion}</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Timeline de Stops -->
  <div class="p-6">
    <div class="relative">
      <!-- Vertical line -->
      <div 
        class="absolute left-4 top-0 bottom-0 w-0.5 bg-gray-200"
        aria-hidden="true"
      ></div>

      <!-- Stops list -->
      <div class="space-y-4">
        {stops.map((stop, idx) => (
          <div class="relative flex items-start gap-4 pl-10">
            <!-- Dot -->
            <div 
              class="absolute left-0 w-8 h-8 rounded-full flex items-center justify-center text-white font-bold text-xs"
              style={`background-color: ${ciudadColor}`}
            >
              {idx + 1}
            </div>

            <!-- Stop content -->
            <div class="flex-1 bg-gray-50 rounded-lg p-3 hover:bg-gray-100 transition-colors duration-200">
              <p class="font-medium text-gray-800">{stop}</p>
            </div>

            <!-- Arrow indicator (except last) -->
            {idx < stops.length - 1 && (
              <div class="absolute left-3.5 -bottom-2 text-gray-400 text-xs" aria-hidden="true">
                ↓
              </div>
            )}
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- Footer con info -->
  <div class="bg-gray-50 px-6 py-4 border-t border-gray-100">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-3 text-sm mb-3">
      <div class="flex items-center gap-2">
        <span class="text-lg">💰</span>
        <span class="text-gray-700">
          <span class="font-semibold" style={`color: ${ciudadColor}`}>Costo:</span>
          {' '}{ruta.costo}
        </span>
      </div>
      <div class="flex items-center gap-2">
        <span class="text-lg">🚶</span>
        <span class="text-gray-700">
          <span class="font-semibold" style={`color: ${ciudadColor}`}>Distancia:</span>
          {' '}{ruta.distancia}
        </span>
      </div>
    </div>

    {ruta.amapUrl && (
      <a
        href={ruta.amapUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center justify-center gap-2 w-full py-2 px-4 rounded-lg text-white font-semibold text-sm hover:opacity-90 transition-opacity"
        style={`background-color: ${ciudadColor}`}
      >
        <span>📍</span>
        <span>Ver ruta en AMap (高德地图)</span>
      </a>
    )}
  </div>
</div>
